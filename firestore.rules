rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // User can read and write only their own profile
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Flows: Participants can read. Only owners can update rules. (Assuming participants is an array of objects or map, let's keep it simple for now)
    match /flows/{flowId} {
      // Basic check: must be authenticated
      allow read: if request.auth != null; 
      // Only owners can create or edit flows
      allow write: if request.auth != null && (request.resource.data.ownerId == request.auth.uid || resource.data.ownerId == request.auth.uid);
    }

    // Transactions
    match /transactions/{transactionId} {
      // Any authenticated user can read transactions for now (in production, restrict to flow participants)
      allow read: if request.auth != null;
      // Users can only create transactions if they are the initiator
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      // Only system (functions) can update status
      allow update: if false; 
    }

    // Wallets 
    match /wallets/{walletId} {
      // Users can only read/write their own wallet
      allow read, write: if request.auth != null && resource.data.userId == request.auth.uid;
    }
  }
}
